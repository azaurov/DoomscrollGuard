<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1A"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gap="14dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⌚ DoomscrollGuard"
            android:textSize="26sp"
            android:textColor="#E0E0FF"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vibrates your Amazfit when you're doom-scrolling"
            android:textSize="13sp"
            android:textColor="#8888AA"
            android:layout_marginBottom="6dp" />

        <!-- Status card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gap="10dp">
                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Checking service status..."
                    android:textColor="#E0E0FF"
                    android:textSize="14sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_accessibility"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable Accessibility Permission →"
                    app:backgroundTint="#4444CC" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Enable toggle -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable Detection"
                        android:textColor="#E0E0FF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="#8888AA"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_enabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Settings card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gap="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SENSITIVITY"
                    android:textColor="#6666AA"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12" />

                <!-- Scroll threshold row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gap="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trigger after"
                        android:textColor="#AAAACC"
                        android:textSize="13sp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:gap="10dp">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_scroll_down"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="‹"
                            android:textSize="20sp"
                            android:padding="0dp"
                            app:backgroundTint="#2A2A4A"
                            app:cornerRadius="22dp" />
                        <TextView
                            android:id="@+id/tv_scroll_value"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="40 scrolls"
                            android:textColor="#E0E0FF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_scroll_up"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="›"
                            android:textSize="20sp"
                            android:padding="0dp"
                            app:backgroundTint="#2A2A4A"
                            app:cornerRadius="22dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A4A" />

                <!-- Window row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gap="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Within a window of"
                        android:textColor="#AAAACC"
                        android:textSize="13sp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:gap="10dp">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_window_down"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="‹"
                            android:textSize="20sp"
                            android:padding="0dp"
                            app:backgroundTint="#2A2A4A"
                            app:cornerRadius="22dp" />
                        <TextView
                            android:id="@+id/tv_window_value"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1 minute"
                            android:textColor="#E0E0FF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_window_up"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="›"
                            android:textSize="20sp"
                            android:padding="0dp"
                            app:backgroundTint="#2A2A4A"
                            app:cornerRadius="22dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A4A" />

                <!-- Cooldown row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gap="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Then wait before alerting again"
                        android:textColor="#AAAACC"
                        android:textSize="13sp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:gap="10dp">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_cooldown_down"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="‹"
                            android:textSize="20sp"
                            android:padding="0dp"
                            app:backgroundTint="#2A2A4A"
                            app:cornerRadius="22dp" />
                        <TextView
                            android:id="@+id/tv_cooldown_value"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="2 minutes"
                            android:textColor="#E0E0FF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_cooldown_up"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="›"
                            android:textSize="20sp"
                            android:padding="0dp"
                            app:backgroundTint="#2A2A4A"
                            app:cornerRadius="22dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Monitored apps -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MONITORED APPS"
                    android:textColor="#6666AA"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Instagram · TikTok · X/Twitter · Reddit · YouTube · Facebook · Pinterest · Snapchat · Tumblr · Chrome · Firefox"
                    android:textColor="#9999BB"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
